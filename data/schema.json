{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Doughnut Economics City Portrait",
  "description": "Schema for a city/region doughnut economics portrait. 12 standard social foundations + 9 standard ecological ceilings, optionally extended with one locally-defined dimension on each side (e.g., 'mobility' and 'waste & materials' for Petaluma).",
  "type": "object",
  "required": ["meta", "social", "ecological"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "name", "region", "country", "population"],
      "properties": {
        "id": { "type": "string", "description": "URL-safe identifier, e.g. 'petaluma_ca'" },
        "name": { "type": "string", "description": "Display name, e.g. 'City of Petaluma'" },
        "region": { "type": "string", "description": "State/province/region" },
        "country": { "type": "string", "description": "Country code (ISO 3166-1)" },
        "population": { "type": "string" },
        "description": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "lastUpdated": { "type": "string", "format": "date" },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "social": {
      "type": "array",
      "minItems": 12,
      "maxItems": 13,
      "items": { "$ref": "#/definitions/dimension" },
      "description": "12 standard social foundation dimensions, optionally with one locally-defined dimension (e.g., 'mobility' for Petaluma)"
    },
    "ecological": {
      "type": "array",
      "minItems": 9,
      "maxItems": 10,
      "items": { "$ref": "#/definitions/dimension" },
      "description": "9 standard ecological ceiling dimensions, optionally with one locally-defined dimension (e.g., 'waste & materials' for Petaluma)"
    }
  },
  "definitions": {
    "dimension": {
      "type": "object",
      "required": ["name", "level", "indicator", "value", "source", "sourceUrl"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "food", "health", "education", "income & work", "housing",
            "water & sanitation", "energy", "social equity",
            "peace & justice", "political voice", "gender equality", "networks",
            "mobility",
            "climate change", "ocean acidification", "chemical pollution",
            "nitrogen & phosphorus loading", "freshwater withdrawals",
            "land conversion", "biodiversity loss", "air pollution",
            "ozone layer depletion",
            "waste & materials"
          ]
        },
        "level": {
          "type": ["number", "null"],
          "minimum": -100,
          "maximum": 150,
          "description": "-100=no problem, -50=under control, 0=on track, 50=needs attention, 100=critical, 150=severe, null=unknown"
        },
        "indicator": { "type": "string", "description": "What metric is being measured" },
        "value": { "type": "string", "description": "The actual data value with units" },
        "year": { "type": ["integer", "null"] },
        "target": { "type": "string" },
        "context": { "type": "string", "description": "2-3 sentences of context" },
        "source": { "type": "string", "description": "Primary source name" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "screenshot": { "type": ["string", "null"] },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "default": "medium"
        },
        "geographicScale": {
          "type": "string",
          "enum": ["city", "county", "metro", "state", "national", "global"],
          "description": "Geographic level of the data"
        },
        "actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "3-5 concrete ways residents can get involved"
        },
        "subIndicators": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "year": { "type": "integer" },
              "source": { "type": "string" },
              "sourceUrl": { "type": "string" }
            }
          },
          "description": "Additional data points for this dimension"
        }
      }
    }
  }
}
